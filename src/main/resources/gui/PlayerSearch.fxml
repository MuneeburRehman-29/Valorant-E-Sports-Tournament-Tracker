<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/21.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.gui.PlayerSearchController">
   <children>
      <VBox alignment="TOP_CENTER" spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>
            <Label text="Valorant Player Search &amp; Database Sync" textFill="#ff4655">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
            
            <HBox alignment="CENTER" spacing="10.0">
               <children>
                  <TextField fx:id="riotIdField" promptText="Riot ID (e.g. TenZ)" />
                  <Label text="#" />
                  <TextField fx:id="tagLineField" promptText="Tagline (e.g. SEN)" prefWidth="80.0"/>
                  <Button fx:id="searchButton" mnemonicParsing="false" onAction="#handleSearch" text="Fetch from API &amp; Save" />
               </children>
            </HBox>
            
            <TextArea fx:id="logOutput" editable="false" prefHeight="250.0" VBox.vgrow="ALWAYS" />
            
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <children>
                  <Button fx:id="loadDbButton" mnemonicParsing="false" onAction="#handleLoadFromDb" text="View Saved Players from DB" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
